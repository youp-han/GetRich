@model Lotto.Models.WeeklySuggestedViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>@ViewBag.SecDist</h3>
<p class="text-muted">@ViewBag.SubTitle</p>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-sm">
        <thead class="thead-dark">
            <tr>
                <th>@ViewBag.ColRange</th>
                <th>@ViewBag.ColPos1</th>
                <th>@ViewBag.ColPos2</th>
                <th>@ViewBag.ColPos3</th>
                <th>@ViewBag.ColPos4</th>
                <th>@ViewBag.ColPos5</th>
                <th>@ViewBag.ColPos6</th>
                <th>@ViewBag.ColBonus</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model.RangeDistributions)
        {
            <tr>
                <td><strong>@r.RangeName</strong></td>
                <td>@r.Pos1Rate.ToString("0.0")%</td>
                <td>@r.Pos2Rate.ToString("0.0")%</td>
                <td>@r.Pos3Rate.ToString("0.0")%</td>
                <td>@r.Pos4Rate.ToString("0.0")%</td>
                <td>@r.Pos5Rate.ToString("0.0")%</td>
                <td>@r.Pos6Rate.ToString("0.0")%</td>
                <td>@r.BonusRate.ToString("0.0")%</td>
            </tr>
        }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>@ViewBag.Note1</small></p>

<hr />

<h3>@ViewBag.SecSets</h3>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th style="min-width:240px">@ViewBag.ColStrat</th>
                <th>1</th>
                <th>2</th>
                <th>3</th>
                <th>4</th>
                <th>5</th>
                <th>6</th>
                <th>@ViewBag.ColBonus</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.SuggestedSets)
        {
            <tr>
                <td><strong>@item.setLabel</strong></td>
                <td>@item.targetNumber1 <small class="text-muted">(@item.targetNumberCount1)</small></td>
                <td>@item.targetNumber2 <small class="text-muted">(@item.targetNumberCount2)</small></td>
                <td>@item.targetNumber3 <small class="text-muted">(@item.targetNumberCount3)</small></td>
                <td>@item.targetNumber4 <small class="text-muted">(@item.targetNumberCount4)</small></td>
                <td>@item.targetNumber5 <small class="text-muted">(@item.targetNumberCount5)</small></td>
                <td>@item.targetNumber6 <small class="text-muted">(@item.targetNumberCount6)</small></td>
                <td><strong>@item.targetNumber7</strong> <small class="text-muted">(@item.targetNumberCount7)</small></td>
            </tr>
        }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>@ViewBag.Note2</small></p>

<hr />

<h3>@ViewBag.SecOverdue</h3>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th style="min-width:240px">@ViewBag.ColStrat</th>
                <th>1</th>
                <th>2</th>
                <th>3</th>
                <th>4</th>
                <th>5</th>
                <th>6</th>
                <th>@ViewBag.ColBonus</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.OverdueSets)
        {
            <tr>
                <td><strong>@item.setLabel</strong></td>
                <td>@item.targetNumber1 <small class="text-muted">(@item.targetNumberCount1)</small></td>
                <td>@item.targetNumber2 <small class="text-muted">(@item.targetNumberCount2)</small></td>
                <td>@item.targetNumber3 <small class="text-muted">(@item.targetNumberCount3)</small></td>
                <td>@item.targetNumber4 <small class="text-muted">(@item.targetNumberCount4)</small></td>
                <td>@item.targetNumber5 <small class="text-muted">(@item.targetNumberCount5)</small></td>
                <td>@item.targetNumber6 <small class="text-muted">(@item.targetNumberCount6)</small></td>
                <td><strong>@item.targetNumber7</strong> <small class="text-muted">(@item.targetNumberCount7)</small></td>
            </tr>
        }
        </tbody>
    </table>
</div>
<p class="text-muted"><small>@ViewBag.NoteOverdue</small></p>
